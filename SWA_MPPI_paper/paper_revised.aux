\@writefile{lot}{\contentsline {table}{\numberline {17}{\ignorespaces Per-country JSD under fixed-$\sigma $ on Qwen2.5-32B. Two latent country clusters emerge: USA/JPN/GBR/KOR strongly prefer high $\sigma $ (USA: $0.0523\to 0.0317$ at $\sigma {=}1.0$); DEU/CHN/BRA/VNM strictly prefer low $\sigma $. All 8 countries share $H\approx 0.52$~nats, so the entropy signal alone cannot discriminate them.}}{20}{table.caption.40}\protected@file@percent }
\newlabel{tab:sigma_percountry}{{17}{20}{Per-country JSD under fixed-$\sigma $ on Qwen2.5-32B. Two latent country clusters emerge: USA/JPN/GBR/KOR strongly prefer high $\sigma $ (USA: $0.0523\to 0.0317$ at $\sigma {=}1.0$); DEU/CHN/BRA/VNM strictly prefer low $\sigma $. All 8 countries share $H\approx 0.52$~nats, so the entropy signal alone cannot discriminate them}{table.caption.40}{}}
