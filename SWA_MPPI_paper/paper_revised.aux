\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces WVS-dimension-to-descriptor mapping used by the persona generator (source: \texttt  {src/personas.py::WVS\_DIMS} and \texttt  {src/persona\_i18n.py}). Each dimension mean is normalised to $[0,1]$ along the positive pole; a quartile cut assigns one of four descriptors ($\geq $0.75 / $\geq $0.50 / $\geq $0.25 / $<$0.25). Direction $-1$ means the raw WVS coding goes high${\to }$negative pole, so the normalised score is $1 -$ raw; direction $+1$ keeps the raw ordering. Negative WVS codes are treated as missing; binary 0/1 items retain raw semantics.}}{20}{table.caption.32}\protected@file@percent }
\newlabel{tab:wvs_thresholds}{{8}{20}{WVS-dimension-to-descriptor mapping used by the persona generator (source: \texttt {src/personas.py::WVS\_DIMS} and \texttt {src/persona\_i18n.py}). Each dimension mean is normalised to $[0,1]$ along the positive pole; a quartile cut assigns one of four descriptors ($\geq $0.75 / $\geq $0.50 / $\geq $0.25 / $<$0.25). Direction $-1$ means the raw WVS coding goes high${\to }$negative pole, so the normalised score is $1 -$ raw; direction $+1$ keeps the raw ordering. Negative WVS codes are treated as missing; binary 0/1 items retain raw semantics}{table.caption.32}{}}
