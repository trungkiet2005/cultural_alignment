\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {SWA-PTIS pipeline.} \textbf  {Left:} WVS Wave~7 data drives the construction of $N{=}4$ country-specific personas (three age cohorts + utilitarian). \textbf  {Middle:} All $N{+}1$ prompts are evaluated in a single batched forward pass; logit gaps are debiased via two-pass positional swapping. \textbf  {Right:} $K{=}128$ perturbations are scored by the Prospect-Theory collective utility and combined into the importance-weighted correction $\delta ^{\star }$. }}{9}{figure.caption.16}\protected@file@percent }
