# Copy to ".env" in the repo root and fill in (".env" is gitignored).
# Hugging Face — read token for gated models (Llama, etc.)
HF_TOKEN=

# Optional alias (hf_env will mirror HF_TOKEN if you only set one)
# HUGGING_FACE_HUB_TOKEN=

# --- Kaggle (no .env in clone): use Notebook secrets instead ---
# Add-ons → Secrets → name: HF_TOKEN → paste read token.
# exp_paper scripts call apply_hf_credentials() which loads .env then Kaggle HF_TOKEN.

# Optional vLLM (read by src/model.py — not passed as unknown VLLM_* env to vLLM 0.19):
# MORAL_VLLM_GPU_MEM=0.92
# MORAL_VLLM_ENFORCE_EAGER=1
