# Copy to ".env" in the repo root and fill in (".env" is gitignored).
# Hugging Face — read token for gated models (Llama, etc.)
HF_TOKEN=

# Optional alias (hf_env will mirror HF_TOKEN if you only set one)
# HUGGING_FACE_HUB_TOKEN=

# --- Kaggle (no .env in clone): use Notebook secrets instead ---
# Add-ons → Secrets → name: HF_TOKEN → paste read token.
# exp_paper scripts call apply_hf_credentials() which loads .env then Kaggle HF_TOKEN.

# Model loader (src/model.py): default Unsloth; set vllm to use vLLM instead.
# MORAL_MODEL_BACKEND=unsloth
# MORAL_MODEL_BACKEND=vllm

# Optional vLLM (read by src/model.py — not passed as unknown VLLM_* env to vLLM 0.19):
# MORAL_VLLM_GPU_MEM=0.92
# MORAL_VLLM_ENFORCE_EAGER=1
# Auto 4-bit (bitsandbytes) when HF id looks like ≥70B (Llama-70B, Qwen-72B, …):
# MORAL_VLLM_AUTO_QUANT_70B=1
# MORAL_VLLM_LARGE_QUANT=bitsandbytes
# VLLM_QUANTIZATION=   # if set, always wins (e.g. awq with an AWQ checkpoint)
# FlashInfer JIT on Qwen3.5+ may need libcuda for linking (Kaggle: cannot find -lcuda):
# MORAL_VLLM_LIBCUDA_DIR=/usr/lib/x86_64-linux-gnu
# MORAL_VLLM_SKIP_LIBCUDA_PATH_FIX=1
