\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Scenario-level conditioning of the DISCA correction.} Per-scenario inter-persona variance (log scale) versus DISCA correction magnitude $|\delta ^\star |$, $n=1{,}550$ scenarios across five countries on Qwen2.5-7B. Each dot is one scenario; the black curve is a Savitzky--Golay smoothed trend. Pearson $r{=}{+}0.372$, $p{<}10^{-3}$: when personas agree (left), DISCA applies near-zero corrections; when they disagree (right), DISCA applies larger corrections. The trend is positive but bounded, so high-disagreement scenarios do not lead to runaway correction magnitudes; isolating how much of this saturation is contributed by the dual-pass reliability gate (versus the IS proposal scale) would require a no-gate ablation that we leave to future work.}}{23}{figure.caption.31}\protected@file@percent }
\newlabel{fig:scenario_corr}{{5}{23}{\textbf {Scenario-level conditioning of the DISCA correction.} Per-scenario inter-persona variance (log scale) versus DISCA correction magnitude $|\delta ^\star |$, $n=1{,}550$ scenarios across five countries on Qwen2.5-7B. Each dot is one scenario; the black curve is a Savitzky--Golay smoothed trend. Pearson $r{=}{+}0.372$, $p{<}10^{-3}$: when personas agree (left), DISCA applies near-zero corrections; when they disagree (right), DISCA applies larger corrections. The trend is positive but bounded, so high-disagreement scenarios do not lead to runaway correction magnitudes; isolating how much of this saturation is contributed by the dual-pass reliability gate (versus the IS proposal scale) would require a no-gate ablation that we leave to future work}{figure.caption.31}{}}
\@writefile{lot}{\contentsline {table}{\numberline {15}{\ignorespaces Per-country mean inter-persona variance $\overline  {D^2}$ and mean correction magnitude $\overline  {|\delta ^\star |}$ ($n=310$ each). Countries are ordered by mean variance. The two extremes (ETH, USA) match expectation; the three middle countries sit in a narrow band, showing the correction is set primarily at the scenario level rather than by a strict country-level monotone mapping.}}{24}{table.caption.32}\protected@file@percent }
\newlabel{tab:scenario_corr}{{15}{24}{Per-country mean inter-persona variance $\overline {D^2}$ and mean correction magnitude $\overline {|\delta ^\star |}$ ($n=310$ each). Countries are ordered by mean variance. The two extremes (ETH, USA) match expectation; the three middle countries sit in a narrow band, showing the correction is set primarily at the scenario level rather than by a strict country-level monotone mapping}{table.caption.32}{}}
