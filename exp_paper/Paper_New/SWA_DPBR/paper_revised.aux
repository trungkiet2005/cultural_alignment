\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {DISCA overview.} Stage~1 builds WVS-grounded persona prompts for a trolley scenario in country~$c$; Stage~2 runs a frozen large language model (LLM) on the base prompt and each persona, aggregates persona-level signals in logit space, and applies \emph  {Prospect-Theory importance sampling} (PT--IS; \S  \ref {sec:method:estimator:gate}) together with a dual-pass reliability gate to obtain the final sparing probability. Pseudocode and the six MultiTP attribute--temperature pairs provided in Appendix~\ref {app:disca_overview}.}}{4}{figure.caption.5}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:disca_overall}{{1}{4}{\textbf {DISCA overview.} Stage~1 builds WVS-grounded persona prompts for a trolley scenario in country~$c$; Stage~2 runs a frozen large language model (LLM) on the base prompt and each persona, aggregates persona-level signals in logit space, and applies \emph {Prospect-Theory importance sampling} (PT--IS; \S \ref {sec:method:estimator:gate}) together with a dual-pass reliability gate to obtain the final sparing probability. Pseudocode and the six MultiTP attribute--temperature pairs provided in Appendix~\ref {app:disca_overview}}{figure.caption.5}{}}
