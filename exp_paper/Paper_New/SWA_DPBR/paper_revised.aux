\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {Geometric story: DISCA pulls model AMCE vectors toward the human cluster.} 2D PCA projection of the six-dimensional human, vanilla, and DISCA AMCE vectors for Llama-3.3-70B across all 20 countries (joint fit, two components capture 93.2\% of the variance). Convex hulls show the spatial extent of each cloud; arrows trace each country's vanilla$\to $DISCA trajectory. \textbf  {All 20 of 20 country points end closer to the human cluster}, with mean $\lVert \text  {model}-\text  {human}\rVert _2$ dropping from 83.3 to 64.6 ($-22.4\%$).}}{8}{figure.caption.6}\protected@file@percent }
\newlabel{fig:amce_pca}{{1}{8}{\textbf {Geometric story: DISCA pulls model AMCE vectors toward the human cluster.} 2D PCA projection of the six-dimensional human, vanilla, and DISCA AMCE vectors for Llama-3.3-70B across all 20 countries (joint fit, two components capture 93.2\% of the variance). Convex hulls show the spatial extent of each cloud; arrows trace each country's vanilla$\to $DISCA trajectory. \textbf {All 20 of 20 country points end closer to the human cluster}, with mean $\lVert \text {model}-\text {human}\rVert _2$ dropping from 83.3 to 64.6 ($-22.4\%$)}{figure.caption.6}{}}
