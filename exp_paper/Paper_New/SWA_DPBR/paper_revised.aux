\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {SWA-DPBR pipeline overview.} \textbf  {Stage~1:} WVS Wave\,7 microdata yields four culturally grounded persona agents per country (three age cohorts $+$ one utilitarian). \textbf  {Stage~2:} A frozen LLM evaluates the base prompt and all personas in a single batched forward pass; each scenario is run twice (A/B swap) for positional debiasing, producing debiased logit gaps $\delta _i$ and per-agent rewards $r_i$. \textbf  {Stage~3:} Two independent Prospect-Theory importance-sampling passes produce corrections $\delta ^\star _1, \delta ^\star _2$; a bootstrap reliability gate (Eq.~\ref {eq:dpbr_rel}) merges them---shrinking the correction exponentially when the passes disagree. \textbf  {Stage~4:} A country-level EMA prior stabilises corrections across scenarios; the annealed blend yields $\delta _{\text  {final}}$ and the culturally-aligned spare probability $p_{\text  {spare}}$. }}{7}{figure.caption.6}\protected@file@percent }
\newlabel{fig:overview}{{1}{7}{\textbf {SWA-DPBR pipeline overview.} \textbf {Stage~1:} WVS Wave\,7 microdata yields four culturally grounded persona agents per country (three age cohorts $+$ one utilitarian). \textbf {Stage~2:} A frozen LLM evaluates the base prompt and all personas in a single batched forward pass; each scenario is run twice (A/B swap) for positional debiasing, producing debiased logit gaps $\delta _i$ and per-agent rewards $r_i$. \textbf {Stage~3:} Two independent Prospect-Theory importance-sampling passes produce corrections $\delta ^\star _1, \delta ^\star _2$; a bootstrap reliability gate (Eq.~\ref {eq:dpbr_rel}) merges them---shrinking the correction exponentially when the passes disagree. \textbf {Stage~4:} A country-level EMA prior stabilises corrections across scenarios; the annealed blend yields $\delta _{\text {final}}$ and the culturally-aligned spare probability $p_{\text {spare}}$}{figure.caption.6}{}}
