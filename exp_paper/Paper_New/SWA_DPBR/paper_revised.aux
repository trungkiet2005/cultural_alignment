\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Per-dimension DISCA improvement across the headline 7 models.} Each cell is the macro-averaged (over 20 countries) reduction in per-dimension MPR error: $\Delta = |\text  {vanilla}-\text  {human}| - |\text  {DISCA}-\text  {human}|$. Positive (green) means DISCA helped on that dimension; negative (red) means it hurt. \textbf  {Utilitarianism}, \textbf  {Species}, and \textbf  {Social Value} are the dimensions where DISCA delivers the largest gains, consistent with these being the dimensions where vanilla error is highest (Table~\ref {tab:perdim_summary}). Cells with $\Delta > 5$~pp shown in bold.}}{20}{figure.caption.19}\protected@file@percent }
\newlabel{fig:per_dim_heatmap}{{2}{20}{\textbf {Per-dimension DISCA improvement across the headline 7 models.} Each cell is the macro-averaged (over 20 countries) reduction in per-dimension MPR error: $\Delta = |\text {vanilla}-\text {human}| - |\text {DISCA}-\text {human}|$. Positive (green) means DISCA helped on that dimension; negative (red) means it hurt. \textbf {Utilitarianism}, \textbf {Species}, and \textbf {Social Value} are the dimensions where DISCA delivers the largest gains, consistent with these being the dimensions where vanilla error is highest (Table~\ref {tab:perdim_summary}). Cells with $\Delta > 5$~pp shown in bold}{figure.caption.19}{}}
