\@writefile{lot}{\contentsline {table}{\numberline {15}{\ignorespaces OLS regression of standardised WVS country features ($n{=}20$ countries, $p{=}10$ predictors) against each MultiTP human AMCE dimension. Both unadjusted $R^2$ and adjusted $R^2$ are reported; the adjusted column is the appropriate quantity given $n/p{=}2$. The unadjusted $R^2$ band of $0.55$--$0.69$ shows that the WVS feature space \emph  {can} explain country-level human AMCE vectors at the required range; the lower adjusted values reflect the small-$n$ regime, not a missing-signal problem.}}{27}{table.caption.52}\protected@file@percent }
\newlabel{tab:r2_wvs_regression}{{15}{27}{OLS regression of standardised WVS country features ($n{=}20$ countries, $p{=}10$ predictors) against each MultiTP human AMCE dimension. Both unadjusted $R^2$ and adjusted $R^2$ are reported; the adjusted column is the appropriate quantity given $n/p{=}2$. The unadjusted $R^2$ band of $0.55$--$0.69$ shows that the WVS feature space \emph {can} explain country-level human AMCE vectors at the required range; the lower adjusted values reflect the small-$n$ regime, not a missing-signal problem}{table.caption.52}{}}
