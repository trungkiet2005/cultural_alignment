\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Geographic distribution of DISCA gain.} Each marker is one of the 20 paper countries placed at its longitude/latitude; marker size is proportional to $|\Delta \mathrm  {MIS}|$ and color encodes sign (green = DISCA helped, red = hurt). Aggregated across the seven headline backbones, \textbf  {19 of 20 countries see a positive mean gain}, with the largest improvements in the Americas, East/Southeast Asia, and Eastern Europe- not concentrated in the West.}}{20}{figure.caption.22}\protected@file@percent }
\newlabel{fig:world_delta_mis}{{4}{20}{\textbf {Geographic distribution of DISCA gain.} Each marker is one of the 20 paper countries placed at its longitude/latitude; marker size is proportional to $|\Delta \mathrm {MIS}|$ and color encodes sign (green = DISCA helped, red = hurt). Aggregated across the seven headline backbones, \textbf {19 of 20 countries see a positive mean gain}, with the largest improvements in the Americas, East/Southeast Asia, and Eastern Europe- not concentrated in the West}{figure.caption.22}{}}
