\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Inference-time baselines on the 20-country Phi-4 grid (macro mean MIS $\downarrow $). MC-Dropout follows \citet  {gal2016dropout, kwon2025dropouts}; DiffPO-binary adapts \citet  {chen2025diffpo} to binary decisions. Calibration baselines fit per-country scalars on a 25\% split against the public human AMCE; SWA-DPBR uses no human AMCE at inference. SWA-DPBR more than halves the residual gap left by the strongest country-agnostic baseline (MC-Dropout), while country-conditioned scalar calibrations actually \emph  {degrade} macro MIS. Per-country tables in Appendix~\ref {app:r2_baselines}.}}{9}{table.caption.11}\protected@file@percent }
\newlabel{tab:r2_baselines_macro_main}{{4}{9}{Inference-time baselines on the 20-country Phi-4 grid (macro mean MIS $\downarrow $). MC-Dropout follows \citet {gal2016dropout, kwon2025dropouts}; DiffPO-binary adapts \citet {chen2025diffpo} to binary decisions. Calibration baselines fit per-country scalars on a 25\% split against the public human AMCE; SWA-DPBR uses no human AMCE at inference. SWA-DPBR more than halves the residual gap left by the strongest country-agnostic baseline (MC-Dropout), while country-conditioned scalar calibrations actually \emph {degrade} macro MIS. Per-country tables in Appendix~\ref {app:r2_baselines}}{table.caption.11}{}}
